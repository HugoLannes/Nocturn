{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nocturn",
  "version": "0.1.0",
  "identifier": "com.hugolannes.nocturn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nocturn",
        "width": 420,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "focus": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
