{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nocturn",
  "version": "0.1.1",
  "identifier": "com.hugolannes.nocturn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nocturn",
        "width": 720,
        "height": 520,
        "resizable": false,
        "fullscreen": false,
        "visible": true,
        "decorations": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "focus": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklEWXlPRU14UWpCR09UQTJRakZCUVRNS1VsZFRha2R0ZFZGRWVIVk5XWFp5VG14WGRHaFVUekJDU2pZck5ubFlPRWhsYjNoWldtdzJNVGt3YjFFeFIyWXdhREJXVURSUU5sVUs=",
      "endpoints": [
        "https://github.com/HugoLannes/nocturn/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
