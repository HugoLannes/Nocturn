{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nocturn",
  "version": "0.1.4",
  "identifier": "com.hugolannes.nocturn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nocturn",
        "width": 720,
        "height": 520,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "visible": true,
        "decorations": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "focus": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "font-src": "'self' asset: http://asset.localhost data:",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      },
      "devCsp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyOEMxQjBGOTA2QjFBQTMKUldTakdtdVFEeHVNWXZyTmxXdGhUTzBCSjYrNnlYOEhlb3hZWmw2MTkwb1ExR2YwaDBWUDRQNlUK",
      "endpoints": [
        "https://github.com/HugoLannes/nocturn/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
